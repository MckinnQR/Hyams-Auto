{
  "name": "hyams-auto-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "process-logo": "python scripts/process-logo.py",
    "dev": "firebase emulators:start --only hosting",
    "serve": "firebase emulators:start --only hosting,functions",
    "serve:hosting": "firebase emulators:start --only hosting",
    "deploy": "firebase deploy --only hosting,functions",
